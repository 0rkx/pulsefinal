# ============================================================================
# may/pulseIQ — upgraded pipeline source folder
# ============================================================================
# Exclude everything that's generated, binary, or environment-specific.
# ONLY the .py source files and .gitignore should be tracked.

# Virtual environment inside may/
may/pulseIQ/.venv/
may/pulseIQ/venv/

# IDE config inside may/
may/pulseIQ/.idea/
may/pulseIQ/.vscode/

# macOS junk inside may/
may/pulseIQ/.DS_Store

# The zip archive (248 MB — definitely don't commit this)
may/pulseIQ.zip

# Generated data inside may/ (re-created by running the pipeline)
may/pulseIQ/pulseiq_data/

# Python bytecode inside may/
may/pulseIQ/__pycache__/
may/pulseIQ/*.py[cod]